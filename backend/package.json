{
  "name": "job-automation-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "cron:once": "node src/scripts/runCronOnce.js",
    "verify:facebook-flow": "node src/scripts/verifyFacebookFlow.js",
    "facebook:test-post": "node src/scripts/testFacebookPost.js",
    "test:job-flow": "node src/scripts/testJobFlow.js",
    "test:job-flow:debug": "node src/scripts/testJobFlow.js --debug",
    "test:job-flow:quick": "node src/scripts/testJobFlow.js --count 2",
    "test:facebook": "node src/scripts/debugFacebook.js --all",
    "test:facebook:verbose": "node src/scripts/debugFacebook.js --all --verbose",
    "debug:facebook": "node src/scripts/debugFacebook.js",
    "setup:facebook-token": "node src/scripts/setupFacebookToken.js",
    "verify:token": "node src/scripts/verifyFacebookToken.js"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.4.1",
    "express-validator": "^7.2.1",
    "helmet": "^8.0.0",
    "mongoose": "^8.8.1",
    "node-cron": "^3.0.3",
    "openai": "^4.68.0",
    "rss-parser": "^3.13.0",
    "slugify": "^1.6.6"
  },
  "devDependencies": {
    "nodemon": "^3.1.7"
  }
