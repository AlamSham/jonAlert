PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://127.0.0.1:27017/job_automation
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash
GROK_API_KEY=your_grok_api_key
GROK_MODEL=grok-2-latest
GROK_BASE_URL=https://api.x.ai/v1
AI_ENABLED=true
AI_QUOTA_COOLDOWN_MINUTES=60
GEMINI_QUOTA_COOLDOWN_MINUTES=60
GROK_QUOTA_COOLDOWN_MINUTES=60
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Facebook Configuration
META_PAGE_ID=your_facebook_page_id
META_GRAPH_VERSION=v25.0

# Automatic Token Management (RECOMMENDED - NEW!)
# Get these from Facebook Developer Console → Your App → Settings → Basic
META_APP_ID=your_facebook_app_id
META_APP_SECRET=your_facebook_app_secret
# After adding above, run: npm run setup:facebook-token
# This will generate never-expiring tokens stored in database

# Legacy Manual Tokens (OPTIONAL - for fallback only)
# These are no longer needed if you use automatic token management
META_PAGE_ACCESS_TOKEN=your_facebook_page_access_token
META_USER_ACCESS_TOKEN=your_facebook_user_access_token

# Token Refresh Cron Schedule (optional)
TOKEN_REFRESH_CRON_SCHEDULE="0 3 * * *"  # Daily at 3 AM (default)
FACEBOOK_AUTOPOST_ENABLED=true
FACEBOOK_POST_DELAY_MS=10000
FACEBOOK_POST_RETRY_DELAY_MS=30000
FACEBOOK_POST_MAX_RETRIES=3
FACEBOOK_REQUEST_TIMEOUT_MS=15000
FACEBOOK_QUEUE_WAIT_TIMEOUT_MS=180000
FACEBOOK_RETRY_DUPLICATE_WINDOW_HOURS=24
CRON_ENABLED=true
FRONTEND_URL=http://localhost:3000
CRON_SECRET=replace_with_strong_random_secret
SCRAPER_USER_AGENT=JobAutomationBot/1.0 (+https://example.com/bot)
# JSON array. type: rss|html, category: job|result|admit-card
JOB_SOURCES_JSON=[{"name":"Sarkari Result RSS","type":"rss","url":"https://example.com/rss/jobs.xml","category":"job"},{"name":"Results RSS","type":"rss","url":"https://example.com/rss/results.xml","category":"result"},{"name":"Admit Cards RSS","type":"rss","url":"https://example.com/rss/admit-cards.xml","category":"admit-card"}]
# Use file-based source config (recommended for many sources)
JOB_SOURCES_FILE=src/data/jobSources.india-starter.json
# Aggressive all-India pack (central + all states + UT + result/admit-card)
# JOB_SOURCES_FILE=src/data/jobSources.india-aggressive.json
